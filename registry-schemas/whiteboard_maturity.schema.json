{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Whiteboard Maturity Registry (Cyberbrain v3.0.1 §3.5)",
  "type": "object",
  "required": ["version", "whiteboards"],
  "properties": {
    "version": { "type": "string" },
    "whiteboards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "whiteboard_id",
          "maturity",
          "maturity_source",
          "last_maturity_reviewed_at"
        ],
        "properties": {
          "whiteboard_id": { "type": "string" },
          "maturity": {
            "type": "string",
            "enum": ["seed", "forming", "structured", "canonical"]
          },
          "maturity_source": {
            "type": "string",
            "enum": ["manual", "heuristic", "meta_card", "title"]
          },
          "last_maturity_reviewed_at": {
            "type": "string",
            "format": "date-time"
          },
          "note": { "type": "string" }
        }
      }
    }
  }
}
